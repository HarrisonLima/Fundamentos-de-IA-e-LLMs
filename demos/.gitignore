```gitignore
# Dependencies
node_modules/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
.nyc_output/

# Build
dist/
build/
out/

# Cache
.cache/
.parcel-cache/
.eslintcache
*.tsbuildinfo

# Environment variables
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Node package managers
.npm/
.pnpm-store/
.yarn/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

# Temporary files
tmp/
temp/

# TensorFlow
tfjs-model/
models/

# Optional lock files (mantenha apenas o que você usa)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
```
